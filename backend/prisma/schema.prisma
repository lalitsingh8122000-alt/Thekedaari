generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  phone     String   @unique @db.VarChar(20)
  password  String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects       Project[]
  roles          Role[]
  contractTrades ContractTrade[]
  workers        Worker[]
  attendances    Attendance[]
  ledgers        LedgerEntry[]
  incomes        Income[]
  expenses       Expense[]
}

model Project {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(200)
  startDate       DateTime
  expectedEndDate DateTime
  type            String   @db.VarChar(20)
  status          String   @default("Running") @db.VarChar(20)
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendances Attendance[]
  incomes     Income[]
  expenses    Expense[]

  @@index([userId])
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  workers Worker[]

  @@index([userId])
}

model ContractTrade {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  workers  Worker[]
  expenses Expense[]

  @@index([userId])
}

model Worker {
  id              Int            @id @default(autoincrement())
  name            String         @db.VarChar(100)
  phone           String         @db.VarChar(20)
  photo           String?        @db.VarChar(500)
  status          String         @default("Active") @db.VarChar(20)
  workerType      String         @default("Labour") @db.VarChar(20)
  costPerDay      Float
  roleId          Int
  role            Role           @relation(fields: [roleId], references: [id])
  contractTradeId Int?
  contractTrade   ContractTrade? @relation(fields: [contractTradeId], references: [id])
  userId          Int
  user            User           @relation(fields: [userId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  attendances   Attendance[]
  ledgerEntries LedgerEntry[]
  expenses      Expense[]

  @@index([userId])
  @@index([roleId])
  @@index([contractTradeId])
}

model Attendance {
  id               Int          @id @default(autoincrement())
  workerId         Int
  worker           Worker       @relation(fields: [workerId], references: [id])
  projectId        Int
  project          Project      @relation(fields: [projectId], references: [id])
  date             DateTime     @db.Date
  type             String       @db.VarChar(20)
  salary           Float
  userId           Int
  user             User         @relation(fields: [userId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  primarySplitId   Int?
  splitParent      Attendance?  @relation("AttendanceSplit", fields: [primarySplitId], references: [id], onDelete: Cascade)
  splitSecondaries Attendance[] @relation("AttendanceSplit")

  ledgerEntry LedgerEntry?

  @@index([workerId])
  @@index([projectId])
  @@index([userId])
  @@index([date])
  @@index([primarySplitId])
}

model LedgerEntry {
  id           Int         @id @default(autoincrement())
  workerId     Int
  worker       Worker      @relation(fields: [workerId], references: [id])
  amount       Float
  type         String      @db.VarChar(20)
  category     String      @db.VarChar(50)
  remarks      String?     @db.VarChar(500)
  comment      String?     @db.Text
  attendanceId Int?        @unique
  attendance   Attendance? @relation(fields: [attendanceId], references: [id])
  expenseId    Int?        @unique
  expense      Expense?    @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId       Int
  user         User        @relation(fields: [userId], references: [id])
  createdAt    DateTime    @default(now())

  @@index([workerId])
  @@index([userId])
  @@index([category])
}

model Income {
  id          Int      @id @default(autoincrement())
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id])
  amount      Float
  date        DateTime @db.Date
  paymentMode String   @db.VarChar(20)
  remarks     String?  @db.VarChar(500)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([userId])
}

model Expense {
  id              Int            @id @default(autoincrement())
  projectId       Int
  project         Project        @relation(fields: [projectId], references: [id])
  amount          Float
  remarks         String         @db.VarChar(500)
  notes           String?        @db.Text
  workerId        Int?
  worker          Worker?        @relation(fields: [workerId], references: [id])
  contractTradeId Int?
  contractTrade   ContractTrade? @relation(fields: [contractTradeId], references: [id])
  date            DateTime       @default(now())
  userId          Int
  user            User           @relation(fields: [userId], references: [id])
  createdAt       DateTime       @default(now())
  ledgerEntry     LedgerEntry?

  @@index([projectId])
  @@index([userId])
  @@index([workerId])
  @@index([contractTradeId])
}

/// CRM / ERP monitor dashboard leads (managed by Prisma migrations)
model Lead {
  id             BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  companyId      BigInt?    @map("company_id") @db.UnsignedBigInt
  name           String     @db.VarChar(150)
  phone          String     @db.VarChar(20)
  email          String?    @db.VarChar(150)
  city           String?    @db.VarChar(100)
  state          String?    @db.VarChar(100)
  pincode        String?    @db.VarChar(10)
  address        String?    @db.Text
  source         String?    @db.VarChar(100)
  status         LeadStatus @default(new_lead)
  leadStage      LeadStage  @default(cold) @map("lead_stage")
  assignedTo     BigInt?    @map("assigned_to") @db.UnsignedBigInt
  remarks        String?    @db.Text
  lastCallAt     DateTime?  @map("last_call_at")
  nextFollowupAt DateTime?  @map("next_followup_at")
  convertedAt    DateTime?  @map("converted_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@index([phone], map: "idx_phone")
  @@index([status], map: "idx_status")
  @@index([assignedTo], map: "idx_assigned_to")
  @@index([companyId], map: "idx_company")
  @@index([createdAt], map: "idx_leads_created_at")
  @@index([nextFollowupAt], map: "idx_leads_next_followup_at")
  @@index([leadStage], map: "idx_leads_lead_stage")
  @@index([source], map: "idx_leads_source")
  @@index([assignedTo, status], map: "idx_leads_assigned_status")
  @@map("leads")
}

enum LeadStatus {
  new_lead
  call_pending
  call_in_progress
  call_not_answered
  call_back
  interested
  demo_scheduled
  demo_done
  demo_pending
  not_interested
  wrong_number
  converted
  lost
}

enum LeadStage {
  cold
  warm
  hot
}
